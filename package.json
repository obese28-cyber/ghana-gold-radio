{
  "name": "ghana-gold-radio",
  "version": "0.2.0",
  "private": true,
  "description": "Ghana Gold Radio - The Sound of Home, Anywhere in the World.",
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "postbuild": "next-sitemap",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "cron:daily": "node scripts/cron/run-daily.js",
    "cron:weekly": "node scripts/cron/run-weekly.js",
    "cron:monthly": "node scripts/cron/run-monthly.js"
  },
  "dependencies": {
    "@google/generative-ai": "^0.17.1",
    "@hookform/resolvers": "^3.9.0",
    "@prisma/client": "^5.18.0",
    "abort-controller": "^3.0.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "event-target-shim": "^6.0.2",
    "isomorphic-dompurify": "^2.14.0",
    "lucide-react": "^0.428.0",
    "next": "14.2.5",
    "next-auth": "^4.24.7",
    "next-sitemap": "^4.2.3",
    "nodemailer": "^7.0.7",
    "openai": "^4.56.0",
    "rate-limiter-flexible": "^5.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.2",
    "sharp": "^0.33.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.46.1",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.15",
    "@types/nodemailer": "^6.4.16",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.41",
    "prisma": "^5.18.0",
    "tailwindcss": "^3.4.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
