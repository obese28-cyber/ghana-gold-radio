# ===========================================
# Ghana Gold Radio - Environment Configuration
# Copy to .env.local for development or .env for production
# NEVER commit real secrets to version control
# ===========================================

# --- App ---
NEXT_PUBLIC_SITE_URL=https://ghanagoldradio.com
NEXT_PUBLIC_SITE_NAME="Ghana Gold Radio"
NODE_ENV=production

# --- PostgreSQL (Docker Compose) ---
# DATABASE_URL must reuse the SAME user/password/db as the POSTGRES_* vars below.
# Host "postgres" = the Docker Compose service name, for use INSIDE the app
# container (real deployment). If you're running Prisma CLI / npm scripts
# directly on your own machine against the dockerized Postgres, change the
# host to "localhost" instead (and make sure docker-compose.yml publishes
# the 5432 port to your host).
POSTGRES_DB=ghana_gold_radio
POSTGRES_USER=ggr
POSTGRES_PASSWORD=replace-with-a-long-random-password
DATABASE_URL=postgresql://ggr:replace-with-a-long-random-password@postgres:5432/ghana_gold_radio?schema=public

# --- Auth / Sessions ---
NEXTAUTH_URL=https://ghanagoldradio.com
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32
ADMIN_EMAIL=admin@ghanagoldradio.com
ADMIN_PASSWORD=replace-with-a-long-unique-password

# --- AI Providers (configurable abstraction, set AI_PROVIDER to 'openai' or 'gemini') ---
AI_PROVIDER=openai
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=replace-me
GEMINI_MODEL=gemini-1.5-flash

# --- Email (SMTP-compatible) ---
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=replace-me
EMAIL_FROM="Ghana Gold Radio <no-reply@ghanagoldradio.com>"
EMAIL_ADMIN_NOTIFY=admin@ghanagoldradio.com

# --- Analytics (privacy-focused) ---
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=ghanagoldradio.com
NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js

# --- Anti-spam ---
TURNSTILE_SITE_KEY=replace-me
TURNSTILE_SECRET_KEY=replace-me

# --- Rate limiting ---
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=20

# --- Cron / Automation security ---
CRON_SECRET=replace-with-long-random-string

# --- File uploads ---
MAX_UPLOAD_MB=15
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
ALLOWED_AUDIO_TYPES=audio/mpeg,audio/wav,audio/x-m4a
UPLOADS_DIR=/app/public/uploads

# --- Cloudflare (for reference / deploy scripts) ---
CLOUDFLARE_ZONE_ID=replace-me
CLOUDFLARE_API_TOKEN=replace-me
